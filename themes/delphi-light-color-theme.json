{
    "name": "Delphi IDE Light",
    "type": "light",
    "semanticHighlighting": true,
    "semanticTokenColors": {
        "type": {
            "foreground": "#990000",
            "bold": true
        },
        "keyword.depth1": {
            "foreground": "#FA0000",
            "bold": true
        },
        "keyword.depth2": {
            "foreground": "#FF9900",
            "bold": true
        },
        "keyword.depth3": {
            "foreground": "#59CB33",
            "bold": true
        },
        "keyword.depth4": {
            "foreground": "#00CED1",
            "bold": true
        },
        "keyword.depth5": {
            "foreground": "#4169E1",
            "bold": true
        },
        "keyword.depth6": {
            "foreground": "#9B59B6",
            "bold": true
        }
    },
    "colors": {
        "editor.background": "#FFFFFF",
        "editor.foreground": "#000000",
        "editor.lineHighlightBackground": "#FAFFE6",
        "editor.selectionBackground": "#B4D5FE",
        "editor.selectionForeground": "#000000",
        "editor.inactiveSelectionBackground": "#D4D4D480",
        "editor.findMatchBackground": "#FFCC80",
        "editor.findMatchForeground": "#000000",
        "editor.findMatchHighlightBackground": "#FFF3CD80",
        "editor.findMatchHighlightForeground": "#000000CC",
        "editorBracketMatch.background": "#00FFFF",
        "editorBracketMatch.border": "#D6CCCC",
        "editorCursor.foreground": "#000000",
        "editorWhitespace.foreground": "#C0C0C0",
        "editorLineNumber.foreground": "#9999CC",
        "editorLineNumber.activeForeground": "#000000",
        "editorGutter.background": "#FFFFFF",
        "editor.foldBackground": "#D4D4D480",
        "editorOverviewRuler.border": "#C0C0C0",
        "editorRuler.foreground": "#C0C0C0",
        "editorError.foreground": "#FF0000",
        "editorWarning.foreground": "#CC8800",
        "editorInfo.foreground": "#008080",
        "editorHint.foreground": "#008000",
        "activityBar.background": "#F0F0F0",
        "activityBar.foreground": "#000000",
        "activityBar.inactiveForeground": "#999999",
        "activityBar.border": "#D4D4D4",
        "activityBarBadge.background": "#007ACC",
        "activityBarBadge.foreground": "#FFFFFF",
        "sideBar.background": "#F0F0F0",
        "sideBar.foreground": "#000000",
        "sideBar.border": "#D4D4D4",
        "sideBarTitle.foreground": "#000000",
        "sideBarSectionHeader.background": "#E8E8E8",
        "sideBarSectionHeader.foreground": "#000000",
        "list.activeSelectionBackground": "#D4D4D4",
        "list.activeSelectionForeground": "#000000",
        "list.inactiveSelectionBackground": "#E8E8E8",
        "list.hoverBackground": "#E8E8E8",
        "list.focusBackground": "#E8E8E8",
        "list.focusForeground": "#000000",
        "statusBar.background": "#F0F0F0",
        "statusBar.foreground": "#000000",
        "statusBar.border": "#D4D4D4",
        "statusBar.debuggingBackground": "#CC0000",
        "statusBar.debuggingForeground": "#FFFFFF",
        "statusBar.noFolderBackground": "#F0F0F0",
        "titleBar.activeBackground": "#E8E8E8",
        "titleBar.activeForeground": "#000000",
        "titleBar.border": "#D4D4D4",
        "menu.background": "#FFFFFF",
        "menu.foreground": "#000000",
        "menu.selectionBackground": "#D4D4D4",
        "menu.border": "#D4D4D4",
        "input.background": "#FFFFFF",
        "input.foreground": "#000000",
        "input.border": "#D4D4D4",
        "input.placeholderForeground": "#999999",
        "inputOption.activeBorder": "#007ACC",
        "focusBorder": "#007ACC",
        "button.background": "#007ACC",
        "button.foreground": "#FFFFFF",
        "button.hoverBackground": "#005A99",
        "dropdown.background": "#FFFFFF",
        "dropdown.foreground": "#000000",
        "dropdown.border": "#D4D4D4",
        "scrollbar.shadow": "#E8E8E8",
        "scrollbarSlider.background": "#C0C0C0",
        "scrollbarSlider.hoverBackground": "#999999",
        "scrollbarSlider.activeBackground": "#007ACC",
        "tab.activeBackground": "#FFFFFF",
        "tab.activeForeground": "#000000",
        "tab.inactiveBackground": "#F0F0F0",
        "tab.inactiveForeground": "#999999",
        "tab.border": "#D4D4D4",
        "tab.activeBorderTop": "#007ACC",
        "terminal.background": "#FFFFFF",
        "terminal.foreground": "#000000",
        "terminal.ansiBlack": "#000000",
        "terminal.ansiRed": "#FF0000",
        "terminal.ansiGreen": "#008000",
        "terminal.ansiYellow": "#808000",
        "terminal.ansiBlue": "#0000FF",
        "terminal.ansiMagenta": "#800080",
        "terminal.ansiCyan": "#008080",
        "terminal.ansiWhite": "#C0C0C0",
        "terminal.ansiBrightBlack": "#808080",
        "terminal.ansiBrightRed": "#FF0000",
        "terminal.ansiBrightGreen": "#008000",
        "terminal.ansiBrightYellow": "#808000",
        "terminal.ansiBrightBlue": "#0000FF",
        "terminal.ansiBrightMagenta": "#800080",
        "terminal.ansiBrightCyan": "#008080",
        "terminal.ansiBrightWhite": "#FFFFFF",
        "diffEditor.insertedTextBackground": "#00800030",
        "diffEditor.removedTextBackground": "#FF000030",
        "diffEditor.insertedLineBackground": "#00800015",
        "diffEditor.removedLineBackground": "#FF000015"
    },
    "tokenColors": [
        {
            "name": "Reserved words, Tags, and all Keywords",
            "scope": [
                "keyword",
                "keyword.control",
                "keyword.other",
                "storage.type",
                "storage.modifier",
                "storage.support",
                "constant.language",
                "entity.name.tag",
                "entity.name.tag.pascal"
            ],
            "settings": {
                "foreground": "#000080",
                "fontStyle": "bold"
            }
        },
        {
            "name": "Comments",
            "scope": [
                "comment",
                "comment.line",
                "comment.block",
                "comment.block.documentation",
                "punctuation.definition.comment",
                "string.regexp"
            ],
            "settings": {
                "foreground": "#008000",
                "fontStyle": "italic"
            }
        },
        {
            "name": "Strings",
            "scope": [
                "string.quoted.single",
                "string.quoted.double"
            ],
            "settings": {
                "foreground": "#0000FF"
            }
        },
        {
            "name": "Numbers and Characters",
            "scope": [
                "constant.numeric",
                "constant.character"
            ],
            "settings": {
                "foreground": "#0000FF"
            }
        },
        {
            "name": "Identifiers",
            "scope": [
                "variable",
                "variable.other",
                "variable.parameter",
                "entity.name",
                "entity.name.function",
                "entity.name.type",
                "support.class",
                "support.constant"
            ],
            "settings": {
                "foreground": "#000000"
            }
        },
        {
            "name": "Symbols, Operators, and Punctuation",
            "scope": [
                "keyword.operator",
                "punctuation",
                "punctuation.terminator",
                "punctuation.separator"
            ],
            "settings": {
                "foreground": "#000000"
            }
        },
        {
            "name": "Preprocessor Directives",
            "scope": [
                "keyword.control.directive",
                "meta.preprocessor"
            ],
            "settings": {
                "foreground": "#008000"
            }
        },
        {
            "name": "Assembler",
            "scope": [
                "source.asm",
                "meta.embedded.asm"
            ],
            "settings": {
                "foreground": "#000000"
            }
        },
        {
            "name": "Attributes",
            "scope": [
                "support.attribute",
                "punctuation.definition.annotation",
                "meta.attribute"
            ],
            "settings": {
                "foreground": "#FF0000"
            }
        },
        {
            "name": "JSON property names",
            "scope": [
                "support.type.property-name.json",
                "support.type.property-name"
            ],
            "settings": {
                "foreground": "#800000"
            }
        },
        {
            "name": "JSON punctuation (braces, brackets, colons, commas)",
            "scope": [
                "punctuation.definition.dictionary.begin.json",
                "punctuation.definition.dictionary.end.json",
                "punctuation.definition.array.begin.json",
                "punctuation.definition.array.end.json",
                "punctuation.separator.dictionary.key-value.json",
                "punctuation.separator.dictionary.pair.json",
                "punctuation.separator.array.json"
            ],
            "settings": {
                "foreground": "#808080"
            }
        },
        {
            "name": "Markdown headings",
            "scope": [
                "markup.heading",
                "punctuation.definition.heading",
                "entity.name.section"
            ],
            "settings": {
                "foreground": "#000080",
                "fontStyle": "bold"
            }
        },
        {
            "name": "Markdown bold",
            "scope": "markup.bold",
            "settings": {
                "foreground": "#000080",
                "fontStyle": "bold"
            }
        },
        {
            "name": "Markdown italic",
            "scope": "markup.italic",
            "settings": {
                "foreground": "#008000",
                "fontStyle": "italic"
            }
        },
        {
            "name": "Markdown blockquotes",
            "scope": [
                "markup.quote",
                "punctuation.definition.quote"
            ],
            "settings": {
                "foreground": "#808080"
            }
        },
        {
            "name": "Markdown list markers",
            "scope": "punctuation.definition.list.begin",
            "settings": {
                "foreground": "#0000FF"
            }
        },
        {
            "name": "Markdown inline code",
            "scope": "markup.inline.raw",
            "settings": {
                "foreground": "#0000FF"
            }
        },
        {
            "name": "Markdown fenced code fences and horizontal rules",
            "scope": [
                "punctuation.definition.markdown",
                "fenced_code.block.language",
                "meta.separator"
            ],
            "settings": {
                "foreground": "#808080"
            }
        },
        {
            "name": "Markdown strikethrough",
            "scope": "markup.strikethrough",
            "settings": {
                "foreground": "#808080",
                "fontStyle": "strikethrough"
            }
        },
        {
            "name": "Hot Links",
            "scope": [
                "markup.underline.link"
            ],
            "settings": {
                "foreground": "#0000FF",
                "fontStyle": "underline"
            }
        },
        {
            "name": "Illegal Characters and Scripts",
            "scope": [
                "invalid.illegal",
                "meta.script",
                "source.script"
            ],
            "settings": {
                "foreground": "#FF0000"
            }
        }
    ]
}
